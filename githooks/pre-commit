#!/bin/sh

# Regex pattern for Google/Gemini API Keys (starts with AIzaSy followed by 35 characters)
KEY_PATTERN="AIzaSy[A-Za-z0-9_-]\{35\}"

# Get list of staged files (Added, Copied, Modified)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for FILE in $STAGED_FILES; do
    # Skip environment template, security doc, and readme files to prevent false positives
    if [ "$FILE" = ".env.example" ] || [ "$FILE" = "SECURITY.md" ] || [ "$FILE" = "README.md" ]; then
        continue
    fi
    
    if [ -f "$FILE" ]; then
        # Search the staged file for raw API keys
        if grep -q "$KEY_PATTERN" "$FILE"; then
            echo "====================================================================="
            echo "[SECURITY REJECTION] Potential raw Google/Gemini API Key detected in: $FILE"
            echo "Please remove the API key and use environment variables instead."
            echo "====================================================================="
            exit 1
        fi
    fi
done

exit 0
